{
  "name": "@zarin071/packt-ds",
  "version": "1.1.2",
  "description": "Packt design system",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": "./src/tokens/tokens.css",
    "./tokens/light": "./src/tokens/tokens.light.css",
    "./tokens/dark": "./src/tokens/tokens.dark.css",
    "./tokens/theme": "./src/tokens/tokens.theme.css",
    "./tailwind.css": "./src/styles/tailwind.css",
    "./material-icons.css": "./src/styles/material-icons.css"
  },
  "scripts": {
    "tokens:dedupe": "node scripts/dedupe-tokens.js",
    "tokens": "node style-dictionary.config.js",
    "build": "tsup",
    "test": "vitest run --project unit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "preversion": "npm test",
    "version": "npm run build",
    "postversion": "git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zarin071/packt-ds.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zarin071/packt-ds/issues"
  },
  "homepage": "https://github.com/zarin071/packt-ds#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src/tokens",
    "src/styles/tailwind.css",
    "src/styles/material-icons.css"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@fontsource-variable/material-symbols-outlined": "^5.3.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/html": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@tokens-studio/sd-transforms": "^1.3.0",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.4.6",
    "style-dictionary": "^4.4.0",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.11",
